# Runtime
APP_ENV=development
API_HOST=127.0.0.1
API_PORT=8000
API_BASE_URL=http://127.0.0.1:8000

# RAG architecture
RAG_ENGINE=llamaindex
LLM_ORCHESTRATION=langchain
LEGACY_RAG_FALLBACK_ENABLED=true
OPENAI_SDK_FALLBACK_ENABLED=true

# OpenRouter / LLM
OPENROUTER_API_KEY=YOUR_OPENROUTER_API_KEY_HERE
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_APP_URL=
OPENROUTER_APP_TITLE=Conversation RAG
LLM_MODEL_NAME=openai/gpt-oss-120b:free

# Embeddings and vector storage
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
RERANKER_MODEL_NAME=cross-encoder/ms-marco-MiniLM-L-6-v2
CHROMA_DB_PATH=./data/chroma_db/
UPLOAD_DIR=./data/uploads

# Pipeline tuning
CHUNK_SIZE=500
CHUNK_OVERLAP=50
RETRIEVAL_TOP_K=6
RERANK_TOP_K=3
SOURCE_CHUNK_LIMIT=3
MEMORY_MAX_TURNS=5
QUERY_REWRITE_ENABLED=true
MAX_GENERATION_TOKENS=512
TEMPERATURE=0.1
